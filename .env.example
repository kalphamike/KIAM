# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin (for authenticated edits - set up in Supabase Dashboard)
VITE_SUPABASE_ADMIN_EMAIL=your-email@example.com
VITE_SUPABASE_ADMIN_PASSWORD=your-password
VITE_ADMIN_USER=admin@example.com
VITE_ADMIN_PASS=SuperSecretPassword123